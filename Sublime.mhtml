@charset "utf-8";

@import url("https://fonts.googleapis.com/css?family=3DPoppins:300,400,500,=
600,700,800,900");

* { margin: 0px; padding: 0px; -webkit-font-smoothing: antialiased; text-sh=
adow: rgba(0, 0, 0, 0.01) 0px 0px 1px; }

body { font-family: Poppins, sans-serif; font-size: 14px; font-weight: 400;=
 background: rgb(255, 255, 255); color: rgb(165, 165, 165); }

div { display: block; position: relative; box-sizing: border-box; }

ul { list-style: none; margin-bottom: 0px; }

p { font-family: Poppins, sans-serif; font-size: 14px; line-height: 2.14; f=
ont-weight: 400; color: rgb(108, 106, 116); -webkit-font-smoothing: antiali=
ased; text-shadow: rgba(0, 0, 0, 0.01) 0px 0px 1px; }

p a { display: inline; position: relative; color: inherit; border-bottom: 1=
